{
  "expo": {
    "name": "CareCo",
    "slug": "careco-users",
    "scheme": "careco-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#0A2463",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.careco.users"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A2463"
      },
      "package": "com.careco.users"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-web-browser",
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      "expo-font"
    ]
  }
}
