{
  "expo": {
    "name": "Samvaya",
    "slug": "careco-users",
    "scheme": "careco-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/Logo.jpg",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/Logo.jpg",
      "backgroundColor": "#0A2463",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.careco.users",
      "infoPlist": {
        "NSHealthShareUsageDescription": "Samvaya requires access to your health data to monitor your wellbeing.",
        "NSHealthUpdateUsageDescription": "Samvaya requires write access to update your health profile."
      }
    },
    "android": {
      "package": "com.careco.users",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-web-browser",
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      "expo-font",
      "@react-native-google-signin/google-signin",
      "expo-notifications",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true,
            "minSdkVersion": 26
          }
        }
      ],
      "react-native-health-connect"
    ],
    "extra": {
      "eas": {
        "projectId": "15b2983e-5c3b-42bb-b810-61bca54d3c4c"
      }
    },
    "owner": "puneeth.2005"
  }
}
