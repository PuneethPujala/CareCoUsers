# React Native Environment Variables

# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=your_supabase_url_here
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# API Configuration — Users App gateway
# Ensure device/emulator can access this host (e.g., Use your LAN IP like 192.168.x.x instead of localhost on physical test devices)
EXPO_PUBLIC_API_URL=http://localhost:3001/api

# Application Configuration
EXPO_PUBLIC_APP_NAME=CareCo
EXPO_PUBLIC_APP_VERSION=1.0.0

# Environment
EXPO_PUBLIC_ENVIRONMENT=development
EXPO_PUBLIC_DEBUG_MODE=true

# Google OAuth Identity Integration
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_google_web_client_id_here
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your_google_android_client_id_here
EXPO_PUBLIC_GOOGLE_PROJECT_ID=your_google_project_id_here
