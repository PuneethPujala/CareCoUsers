{
  "expo": {
    "name": "CareMyMed",
    "slug": "careco-users",
    "scheme": "caremymed-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/Splash.png",
      "backgroundColor": "#F0F7FF",
      "resizeMode": "contain"
    },
    "ios": {
      "splash": {
        "image": "./assets/Splash.png",
        "backgroundColor": "#F0F7FF",
        "resizeMode": "contain",
        "tabletImage": "./assets/Splash.png",
        "dark": {
          "image": "./assets/Splash.png",
          "backgroundColor": "#F0F7FF",
          "resizeMode": "contain"
        }
      },
      "supportsTablet": true,
      "bundleIdentifier": "com.careco.users",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSHealthShareUsageDescription": "CareMyMed requires access to your health data to monitor your wellbeing.",
        "NSHealthUpdateUsageDescription": "CareMyMed requires write access to update your health profile.",
        "NSMicrophoneUsageDescription": "CareMyMed requires microphone access to connect you with your dedicated care coordinator."
      }
    },
    "android": {
      "splash": {
        "image": "./assets/Splash.png",
        "backgroundColor": "#F0F7FF",
        "resizeMode": "contain",
        "dark": {
          "image": "./assets/Splash.png",
          "backgroundColor": "#F0F7FF",
          "resizeMode": "contain"
        }
      },
      "package": "com.careco.users",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.health.READ_HEART_RATE",
        "android.permission.health.READ_BLOOD_PRESSURE",
        "android.permission.health.READ_SLEEP_SESSION",
        "android.permission.health.READ_OXYGEN_SATURATION",
        "android.permission.health.READ_HYDRATION",
        "android.permission.health.READ_BODY_TEMPERATURE",
        "android.permission.health.READ_STEPS",
        "android.permission.health.READ_DISTANCE",
        "android.permission.health.READ_EXERCISE",
        "android.permission.health.READ_ACTIVE_CALORIES_BURNED",
        "android.permission.health.READ_TOTAL_CALORIES_BURNED",
        "android.permission.health.READ_FLOORS_CLIMBED",
        "android.permission.health.READ_VO2_MAX",
        "android.permission.health.READ_WEIGHT",
        "android.permission.health.READ_HEIGHT",
        "android.permission.health.READ_BODY_FAT",
        "android.permission.health.READ_BLOOD_GLUCOSE",
        "android.permission.health.READ_RESPIRATORY_RATE",
        "android.permission.PACKAGE_USAGE_STATS"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-web-browser",
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      "expo-font",
      "@react-native-google-signin/google-signin",
      "expo-notifications",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true,
            "minSdkVersion": 26,
            "packagingOptions": {
              "pickFirst": [
                "**/libc++_shared.so"
              ]
            }
          }
        }
      ],
      [
        "expo-health-connect",
        {
          "requestPermissionsActivityName": ".MainActivity"
        }
      ],
      [
        "react-native-health-connect",
        {
          "permissions": [
            "READ_HEART_RATE",
            "READ_BLOOD_PRESSURE",
            "READ_SLEEP_SESSION",
            "READ_OXYGEN_SATURATION",
            "READ_HYDRATION",
            "READ_BODY_TEMPERATURE",
            "READ_STEPS",
            "READ_DISTANCE",
            "READ_EXERCISE",
            "READ_ACTIVE_CALORIES_BURNED",
            "READ_TOTAL_CALORIES_BURNED",
            "READ_FLOORS_CLIMBED",
            "READ_VO2_MAX",
            "READ_WEIGHT",
            "READ_HEIGHT",
            "READ_BODY_FAT",
            "READ_BLOOD_GLUCOSE",
            "READ_RESPIRATORY_RATE"
          ]
        }
      ],
      "./plugins/withAndroidWidget.js",
      "./plugins/withUsageStatsPermission.js",
      "expo-localization",
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you choose a profile picture.",
          "cameraPermission": "The app accesses your camera to let you take a profile picture."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "3eeed402-2786-427b-b122-e73d681dcc56"
      }
    },
    "owner": "puneeth.26"
  }
}
