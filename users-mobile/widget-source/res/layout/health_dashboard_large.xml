<?xml version="1.0" encoding="utf-8"?>
<!-- Health Dashboard — LARGE (4×2): Vitals + 7-day trend -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_adaptive"
    android:orientation="horizontal"
    android:padding="14dp">

    <!-- Left: 2×2 Vitals grid -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginEnd="10dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="My Vitals"
            android:textColor="@color/widget_text_primary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <!-- Row 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="3dp"
                android:layout_marginBottom="3dp"
                android:background="@drawable/widget_vitals_cell_bg"
                android:orientation="vertical"
                android:padding="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="HR" android:textSize="10sp" android:textColor="@color/widget_vital_heart" android:textStyle="bold" />
                <TextView android:id="@+id/vital_heart_rate" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="—"
                    android:textColor="@color/widget_text_primary" android:textSize="16sp"
                    android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="bpm" android:textColor="@color/widget_text_muted"
                    android:textSize="8sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="3dp"
                android:layout_marginBottom="3dp"
                android:background="@drawable/widget_vitals_cell_bg"
                android:orientation="vertical"
                android:padding="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="BP" android:textSize="10sp" android:textColor="@color/widget_vital_bp" android:textStyle="bold" />
                <TextView android:id="@+id/vital_bp" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="—"
                    android:textColor="@color/widget_text_primary" android:textSize="16sp"
                    android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="mmHg" android:textColor="@color/widget_text_muted"
                    android:textSize="8sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Row 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="3dp"
                android:layout_marginTop="3dp"
                android:background="@drawable/widget_vitals_cell_bg"
                android:orientation="vertical"
                android:padding="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="O2" android:textSize="10sp" android:textColor="@color/widget_vital_oxygen" android:textStyle="bold" />
                <TextView android:id="@+id/vital_oxygen" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="—"
                    android:textColor="@color/widget_text_primary" android:textSize="16sp"
                    android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="%" android:textColor="@color/widget_text_muted"
                    android:textSize="8sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="3dp"
                android:layout_marginTop="3dp"
                android:background="@drawable/widget_vitals_cell_bg"
                android:orientation="vertical"
                android:padding="6dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="H2O" android:textSize="10sp" android:textColor="@color/widget_vital_hydration" android:textStyle="bold" />
                <TextView android:id="@+id/vital_hydration" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="—"
                    android:textColor="@color/widget_text_primary" android:textSize="16sp"
                    android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="%" android:textColor="@color/widget_text_muted"
                    android:textSize="8sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Right: AI Status + Trend info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- AI Badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="8dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI Health Outlook"
                android:textColor="@color/widget_text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />
            <TextView
                android:id="@+id/widget_ai_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/widget_pill_bg"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="Healthy ✓"
                android:textColor="@color/widget_ai_healthy"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- 7-day HR trend (text-based since RemoteViews can't do charts) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@drawable/widget_vitals_cell_bg"
            android:orientation="vertical"
            android:padding="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="7-Day Heart Rate"
                android:textColor="@color/widget_text_muted"
                android:textSize="10sp"
                android:layout_marginBottom="4dp" />

            <!-- Simple text-based trend display -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="bottom">

                <TextView android:id="@+id/trend_d1" android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="wrap_content" android:text="—" android:textSize="9sp"
                    android:textColor="@color/widget_vital_heart" android:gravity="center" />
                <TextView android:id="@+id/trend_d2" android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="wrap_content" android:text="—" android:textSize="9sp"
                    android:textColor="@color/widget_vital_heart" android:gravity="center" />
                <TextView android:id="@+id/trend_d3" android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="wrap_content" android:text="—" android:textSize="9sp"
                    android:textColor="@color/widget_vital_heart" android:gravity="center" />
                <TextView android:id="@+id/trend_d4" android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="wrap_content" android:text="—" android:textSize="9sp"
                    android:textColor="@color/widget_vital_heart" android:gravity="center" />
                <TextView android:id="@+id/trend_d5" android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="wrap_content" android:text="—" android:textSize="9sp"
                    android:textColor="@color/widget_vital_heart" android:gravity="center" />
                <TextView android:id="@+id/trend_d6" android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="wrap_content" android:text="—" android:textSize="9sp"
                    android:textColor="@color/widget_vital_heart" android:gravity="center" />
                <TextView android:id="@+id/trend_d7" android:layout_width="0dp" android:layout_weight="1"
                    android:layout_height="wrap_content" android:text="—" android:textSize="9sp"
                    android:textColor="@color/widget_vital_heart" android:gravity="center" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="2dp">
                <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                    android:text="M" android:textSize="8sp" android:textColor="@color/widget_text_muted" android:gravity="center" />
                <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                    android:text="T" android:textSize="8sp" android:textColor="@color/widget_text_muted" android:gravity="center" />
                <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                    android:text="W" android:textSize="8sp" android:textColor="@color/widget_text_muted" android:gravity="center" />
                <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                    android:text="T" android:textSize="8sp" android:textColor="@color/widget_text_muted" android:gravity="center" />
                <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                    android:text="F" android:textSize="8sp" android:textColor="@color/widget_text_muted" android:gravity="center" />
                <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                    android:text="S" android:textSize="8sp" android:textColor="@color/widget_text_muted" android:gravity="center" />
                <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content"
                    android:text="S" android:textSize="8sp" android:textColor="@color/widget_text_muted" android:gravity="center" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
