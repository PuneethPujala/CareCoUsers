# ==============================================================================
# CareMyMed — Git Ignore Rules
# ==============================================================================

# ── Dependencies ──────────────────────────────────────────────
node_modules/

# ── Environment / Secrets (CRITICAL — never commit .env files) ─
.env
.env.local
.env.*.local
backend/.env
backend/.env.example
admin-app/.env
users-backend/.env
users-mobile/.env

# ── Expo / React Native ──────────────────────────────────────
.expo/
dist/
web-build/
expo-env.d.ts
.metro-health-check*

# ── Native build artifacts ───────────────────────────────────
/ios
/android
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.pem

# ── Debug / Logs ─────────────────────────────────────────────
npm-debug.*
yarn-debug.*
yarn-error.*
*.log

# ── OS files ─────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── TypeScript ───────────────────────────────────────────────
*.tsbuildinfo

# ── Python cache ─────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo

# ── Backend scratch / test / debug files ─────────────────────
backend/scripts/
backend/test*.js
backend/test*.json
backend/*.txt
backend/*.json
!backend/package.json
!backend/package-lock.json
backend/cleanup.js
backend/clear-cache.js
backend/debug_caller.js
backend/fix_caretaker.js
backend/generateTodayCalls.js
backend/nuke.js
backend/seed_patients.js
backend/wipe_profiles.js
backend/log_dump.json

# ── Users-backend scratch files ──────────────────────────────
users-backend/testAnomalySync.js
users-backend/testPush.js
users-backend/reset-users.js
users-backend/migrate-patient-profiles.js

# ── AI vitals output ─────────────────────────────────────────
users-ai-vitals/output.txt

# -- Root scratch files ---------------------------------------
/*.js
