# Supabase Configuration
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# MongoDB Configuration
MONGODB_URI=your_mongodb_connection_string_here

# Server Configuration
PORT=3001
NODE_ENV=development

# Security — JWT (required for email/password auth; generate strong random strings)
JWT_SECRET=change_me_use_long_random_string
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_MS=604800000
BCRYPT_ROUNDS=12
# Optional: allow legacy Supabase tokens + password migration (Google OAuth / old accounts)
AUTH_ENABLE_SUPABASE_FALLBACK=false

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=60
AUTH_LOGIN_RATE_LIMIT_MAX=25

# Frontend URL (for password reset redirects)
FRONTEND_URL=http://localhost:3000

# SMTP / Email Configuration for automated notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_smtp_email_here@example.com
SMTP_PASS=your_16_char_app_password_here
FROM_EMAIL=your_sending_email_here@example.com
