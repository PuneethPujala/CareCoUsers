{
  "expo": {
    "name": "CareCo Admin Portal",
    "slug": "careco-admin",
    "scheme": "careco-admin",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A2463"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.careco.admin"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "monochromeImage": "./assets/android-icon-monochrome.png",
        "backgroundColor": "#0A2463"
      },
      "package": "com.careco.admin"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-web-browser",
      "expo-font",
      "expo-splash-screen"
    ],
    "extra": {
      "eas": {
        "projectId": "15eed2df-88f7-4f51-b924-88218c54b7be"
      }
    }
  }
}
